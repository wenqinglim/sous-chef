# Copy this file to .env.local and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key — required for Instagram audio fallback (whisper-large-v3).
# Free tier: 100 audio minutes/day. Sign up at https://console.groq.com
GROQ_API_KEY=gsk_...

# Instagram session cookie — required to import Instagram reels. Instagram now
# login-walls both the caption and the video for logged-out/server requests, so
# without this a reel's recipe (and its narrated audio) can't be read.
# How to get it: log in to instagram.com in your browser → DevTools → Application
# → Cookies → https://www.instagram.com → copy the value of the `sessionid` cookie.
# It expires every few months; re-paste when reel imports start failing.
IG_SESSIONID=

# Shared recipe library (Postgres). In production this is injected by the
# Vercel Marketplace → Neon integration; for local dev paste the Neon
# connection string or point at a local Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
