# Copy this file to .env.local and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key — required for Instagram audio fallback (whisper-large-v3).
# Free tier: 100 audio minutes/day. Sign up at https://console.groq.com
GROQ_API_KEY=gsk_...

# Apify API token — used to import Instagram reels. Instagram login-walls
# server requests from datacenter IPs (Vercel's), so a third-party scraper
# fetches the reel's caption + video on its own residential infra instead. No
# personal Instagram credentials are involved. Without this, reel imports fall
# back to pasting the caption manually in the UI.
# How to get it: sign up at https://console.apify.com → Settings → API & Integrations
# → copy your Personal API token. Free tier ($5/mo platform credit) easily covers
# personal use of the apify/instagram-scraper actor.
APIFY_TOKEN=apify_api_...

# Shared recipe library (Postgres). In production this is injected by the
# Vercel Marketplace → Neon integration; for local dev paste the Neon
# connection string or point at a local Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
